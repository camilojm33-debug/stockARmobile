+             <td>{{ movement.detail }}</td>
+             <td class="text-end">{{ "%.3g"|format(movement.quantity) if movement.quantity is not none else '-' }}</td>
+             <td class="text-end">{{ "$%.2f"|format(movement.unit_value) if movement.unit_value is not none else '-' }}</td>
+           </tr>
+           {% else %}
+           <tr><td colspan="5" class="text-center text-muted py-5">Todavia no hay movimientos para este producto.</td></tr>
+           {% endfor %}
